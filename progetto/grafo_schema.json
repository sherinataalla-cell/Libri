{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "coinquilini_per_contratto/grafo_schema.json",
  "title": "Grafo narrativo Coinquilini per Contratto",
  "description": "Schema canonico del grafo. Specializzazione del template kit per un romance contemporaneo a doppio POV (Francesca/Giovanni), 20 capitoli, 3 atti, prima persona presente. DA COMPLETARE in Fase 02 con lo skill architetto_grafo.",
  "type": "object",
  "required": ["schema_version", "graph_version", "project", "entities", "units"],
  "properties": {
    "schema_version": {
      "type": "string",
      "description": "Versione della FORMA dei nodi. Semver — major bump vietato post-congelamento.",
      "default": "1.0.0",
      "pattern": "^\\d+\\.\\d+(\\.\\d+)?$"
    },
    "graph_version": {
      "type": "string",
      "description": "Versione dello STATO del contenuto.",
      "default": "0.0.0",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "project": {
      "type": "object",
      "required": ["id", "title", "medium"],
      "properties": {
        "id": { "type": "string", "default": "coinquilini_per_contratto" },
        "title": { "type": "string", "default": "Coinquilini per Contratto" },
        "subtitle": { "type": "string", "default": "Romance contemporaneo — Francesca Ferrante & Giovanni Liguori" },
        "medium": { "type": "string", "enum": ["testo"], "default": "testo" },
        "target_audience": { "type": "string", "default": "KDP Select / Kindle Unlimited" },
        "language": { "type": "string", "default": "it" },
        "created_at": { "type": "string", "format": "date" },
        "updated_at": { "type": "string", "format": "date" }
      }
    },
    "entities": {
      "type": "object",
      "description": "Categorie: characters, locations, groups, objects.",
      "properties": {
        "characters": {
          "type": "object",
          "description": "Personaggi. Sottocategorie: protagonisti, secondari, personaggio_ponte.",
          "additionalProperties": {
            "type": "object",
            "required": ["id", "name", "category"],
            "properties": {
              "id": { "type": "string", "pattern": "^[a-z0-9_]+$" },
              "name": { "type": "string" },
              "aliases": { "type": "array", "items": { "type": "string" } },
              "category": { "type": "string", "enum": ["protagonisti", "secondari", "personaggio_ponte", "antagonisti"] },
              "role_saga": { "type": "string" },
              "appears_in_units": { "type": "array", "items": { "type": "string" } },
              "stato_per_unita": { "type": "object" },
              "voice": {
                "type": "object",
                "description": "Registro voce — calcolo/controllo (Francesca) o materico/restauro (Giovanni).",
                "properties": {
                  "register": { "type": "string" },
                  "frasi_codice": { "type": "array", "items": { "type": "string" } },
                  "verbi_dominanti": { "type": "array", "items": { "type": "string" } },
                  "lessico_tipico": { "type": "array", "items": { "type": "string" } },
                  "vincoli_max": { "type": "object" }
                }
              },
              "arc_summary": { "type": "string" },
              "ferita": { "type": "string" },
              "want": { "type": "string" },
              "need": { "type": "string" },
              "links": { "type": "object" },
              "promotion": { "type": "object" }
            }
          }
        },
        "locations": {
          "type": "object",
          "description": "Luoghi. Sottocategorie: privati, pubblici.",
          "additionalProperties": { "type": "object" }
        },
        "groups": {
          "type": "object",
          "description": "Organizzazioni, fondi, reti.",
          "additionalProperties": { "type": "object" }
        },
        "objects": {
          "type": "object",
          "description": "Oggetti narrativamente rilevanti (clausola, affreschi, simboli).",
          "additionalProperties": { "type": "object" }
        }
      }
    },
    "units": {
      "type": "object",
      "description": "Unità narrative (capitoli). Chiave = id unità (es. cap_01).",
      "additionalProperties": {
        "type": "object",
        "required": ["id", "title", "position"],
        "properties": {
          "id": { "type": "string", "pattern": "^cap_\\d{2}$" },
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "position": { "type": "integer", "minimum": 1, "maximum": 20 },
          "block_id": {
            "type": "string",
            "description": "Atto narrativo.",
            "enum": ["la_gabbia", "il_patto", "la_terza_via"]
          },
          "pov_a": { "type": "string", "description": "Prima sezione PoV (sempre Francesca).", "default": "francesca" },
          "pov_b": { "type": "string", "description": "Seconda sezione PoV (sempre Giovanni).", "default": "giovanni" },
          "heat_level": {
            "type": "string",
            "description": "Temperatura della scena.",
            "enum": ["tensione", "crepa", "esplicito_errore", "esplicito_patto", "esplicito_scelta"]
          },
          "hook_type": {
            "type": "string",
            "description": "Tipo hook di chiusura capitolo.",
            "enum": ["azione", "emotivo", "ribaltamento_pov", "promessa_calda", "domanda_aperta"]
          },
          "premise": { "type": "string" },
          "beat_a": { "type": "string", "description": "Beat sezione Francesca" },
          "beat_b": { "type": "string", "description": "Beat sezione Giovanni" },
          "palazzo_beat": { "type": "string", "description": "Stato fisico del palazzo in questo capitolo" },
          "cast_in_scene": { "type": "array", "items": { "type": "object" } },
          "primary_location_id": { "type": "string" },
          "scenes": { "type": "array", "items": { "type": "object" } },
          "narrazione_fattuale_path": { "type": "string" },
          "brief_path": { "type": ["string", "null"] },
          "testo_finale_path": { "type": ["string", "null"] },
          "status": {
            "type": "string",
            "enum": ["idea", "macro_distilled", "micro_distilled", "briefed", "prose_draft", "final"],
            "default": "idea"
          },
          "seeds_planted": { "type": "array", "items": { "type": "string" } },
          "seeds_blooming": { "type": "array", "items": { "type": "string" } },
          "debts_opened": { "type": "array", "items": { "type": "string" } },
          "debts_closed": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "global_relations": {
      "type": "object",
      "properties": {
        "narrative_promises": { "type": "object" },
        "explicit_callbacks": { "type": "object" },
        "narrative_debts": { "type": "object" },
        "character_arcs": { "type": "object" }
      }
    },
    "quote_tracker": {
      "type": "object",
      "description": "Tracker frasi-codice e pattern ricorrenti. DA POPOLARE in Fase 02.",
      "additionalProperties": { "type": "object" }
    },
    "misalignments_path": { "type": "string", "default": "misalignments.json" },
    "audit": { "type": "object" }
  }
}
